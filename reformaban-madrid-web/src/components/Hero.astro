---
interface Props {
  h1: string;
  subtitle: string;
  trustItem?: string;
  ctaPrimary: string;
  ctaPrimaryHref: string;
  ctaSecondary?: string;
  ctaSecondaryHref?: string;
}

const {
  h1,
  subtitle,
  trustItem,
  ctaPrimary,
  ctaPrimaryHref,
  ctaSecondary,
  ctaSecondaryHref,
} = Astro.props;
---

<section class="bg-gradient-to-b from-primary-50 to-white">
  <div class="container-narrow py-16 md:py-24 text-center">
    <h1 class="mb-6">{h1}</h1>
    <p class="text-lg md:text-xl text-gray-700 mb-8 max-w-prose mx-auto">
      {subtitle}
    </p>

    {trustItem && (
      <p class="text-sm text-gray-500 mb-6">★★★★★ {trustItem}</p>
    )}

    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a href={ctaPrimaryHref} class="btn-primary">
        {ctaPrimary}
      </a>
      {ctaSecondary && ctaSecondaryHref && (
        <a href={ctaSecondaryHref} class="btn-accent">
          {ctaSecondary}
        </a>
      )}
    </div>
  </div>
</section>
