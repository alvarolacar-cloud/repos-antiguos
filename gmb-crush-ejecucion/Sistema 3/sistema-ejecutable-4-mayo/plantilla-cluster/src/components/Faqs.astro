---
import type { FAQ } from "@lib/types";

interface Props {
  title?: string;
  faqs: FAQ[];
}

const { title = "Preguntas frecuentes", faqs } = Astro.props;
---

{
  faqs && faqs.length > 0 && (
    <section class="section">
      <div class="container-narrow">
        <h2 class="text-center mb-10">{title}</h2>
        <div class="space-y-4">
          {faqs.map((f) => (
            <details class="border border-gray-200 rounded-xl p-6">
              <summary class="font-semibold cursor-pointer">{f.q}</summary>
              <p class="mt-3 text-gray-700">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  )
}
