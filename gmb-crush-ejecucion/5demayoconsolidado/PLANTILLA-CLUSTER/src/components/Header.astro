---
import { getBusinessName, getServices, getNAP, getPreferredCTA, getMainCitySlug, getPrimaryCategorySlug, phoneHref } from "@lib/cluster";

const businessName = getBusinessName();
const services = getServices();
const nap = getNAP();
const cta = getPreferredCTA();
const mainCitySlug = getMainCitySlug();
const primaryCatSlug = getPrimaryCategorySlug();
---

<header class="bg-white border-b border-gray-200 sticky top-0 z-50">
  <div class="container-wide flex items-center justify-between py-4">
    <a href="/" class="text-xl font-bold text-primary-900 no-underline">
      {businessName}
    </a>

    <nav class="hidden md:flex items-center gap-6">
      {services.slice(0, 3).map((s) => (
        <a
          href={`/${primaryCatSlug}/${mainCitySlug}/${s.slug}/`}
          class="text-sm text-gray-700 hover:text-primary-500 no-underline"
        >
          {s.name}
        </a>
      ))}
      <a href="/contacto/" class="text-sm text-gray-700 hover:text-primary-500 no-underline">
        Contacto
      </a>
    </nav>

    <div class="flex items-center gap-3">
      <a href={phoneHref(nap.phone)} class="hidden sm:inline-flex items-center text-sm font-semibold text-primary-900 no-underline">
        {nap.phone}
      </a>
      <a href="/contacto/" class="btn-primary text-sm py-2 px-4">
        {cta}
      </a>
    </div>
  </div>
</header>
